# =============================================================================
# Workflow Architecture — 4 operational flows
# =============================================================================
# Render:
#   Playground: https://play.d2lang.com → paste this file
#   Local:      d2 docs/architecture-workflows.d2 docs/arch-flows.svg
#   Watch:      d2 --watch docs/architecture-workflows.d2
# =============================================================================

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    pad: 40
  }
}

title: |md
  # Cluster Workflows
  ### 4 operational flows: deploy · restore · alert · backup
| {near: top-center}

# =============================================================================
# Flow 1 — Deployment pipeline (developer → users)
# =============================================================================

deploy_flow: "1 · Deployment pipeline (GitOps + Image Updater)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  dev: Developer {
    shape: person
    style.fill: "#FFE0B2"
  }

  build: podman build\n(ARM64 native) {
    shape: step
    style.fill: "#BBDEFB"
  }

  push: podman push {
    shape: step
    style.fill: "#BBDEFB"
  }

  gitea_reg: Gitea OCI registry {
    shape: image
    icon: https://about.gitea.com/img/logo.svg
    style.fill: "#609926"
  }

  updater: Image Updater v1.1 {
    shape: image
    icon: https://argo-cd.readthedocs.io/en/stable/assets/logo.png
    style.fill: "#EF7B4D"
    tooltip: polls registry every 2 min, CRD-based
  }

  gitea_git: Gitea Kustomize repo {
    shape: image
    icon: https://about.gitea.com/img/logo.svg
    style.fill: "#609926"
  }

  argocd: ArgoCD {
    shape: image
    icon: https://argo-cd.readthedocs.io/en/stable/assets/logo.png
    style.fill: "#EF7B4D"
  }

  pods: Running pods\n(eve-tracker prod + dev) {
    shape: package
    style.fill: "#B3E5FC"
  }

  tunnel: Cloudflare Tunnel {
    shape: cloud
    style.fill: "#F48FB1"
  }

  users: End users {
    shape: person
    style.fill: "#FFE0B2"
  }

  dev -> build
  build -> push
  push -> gitea_reg: :latest or :dev {style.bold: true}
  gitea_reg -> updater: new digest detected
  updater -> gitea_git: writeBackMethod=git\ncommits kustomization patch {style.stroke: "#4CAF50"}
  gitea_git -> argocd: webhook / polling
  argocd -> pods: sync (Kustomize + digest override) {style.bold: true}
  pods -> tunnel: egress via cloudflared DaemonSet
  tunnel -> users: HTTPS eve.example.com
}

# =============================================================================
# Flow 2 — Restore from R2 (make restore-volumes)
# =============================================================================

restore_flow: "2 · R2 restore workflow (make restore-volumes)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  operator: Operator\nmake restore-volumes {
    shape: person
    style.fill: "#FFE0B2"
  }

  r2: Cloudflare R2\nk8sbkp/longhorn/ {
    shape: cloud
    style.fill: "#F48FB1"
  }

  backup_target: Longhorn BackupTarget {
    shape: image
    icon: https://longhorn.io/img/logos/longhorn-icon-color.png
  }

  bv: BackupVolume CRs\n(synced from R2) {
    shape: class
    label: |md
      **BackupVolume CRs**
      status.labels.KubernetesStatus
      ↓
      {namespace, pvcName}
    |
  }

  discover: Discover\njq KubernetesStatus {
    shape: step
    style.fill: "#E1BEE7"
  }

  resolve: Resolve latest Backup URL {
    shape: step
    style.fill: "#E1BEE7"
  }

  validate: Fail-fast validation\n(missing backup = abort) {
    shape: step
    style.fill: "#FFAB91"
  }

  volume_cr: Volume CR\nrestored-<md5:12> {
    shape: hexagon
    style.fill: "#CE93D8"
    label: |md
      **longhorn.io/Volume**
      `fromBackup: s3://...`
    |
  }

  detached: Wait for state=detached\n(Longhorn pulls blocks) {
    shape: step
    style.fill: "#CE93D8"
  }

  pv: Static PersistentVolume\n(csi driver.longhorn.io) {
    shape: page
    style.fill: "#BA68C8"
  }

  pvc: PersistentVolumeClaim\n+ strip last-applied-config {
    shape: page
    style.fill: "#BA68C8"
  }

  pod: Workload pod\n(mounts restored data) {
    shape: package
    style.fill: "#B3E5FC"
  }

  operator -> backup_target: apply BackupTarget CR
  backup_target -> r2: poll every 5 min
  r2 -> bv: discover backups
  bv -> discover
  discover -> resolve
  resolve -> validate
  validate -> volume_cr: create per target
  volume_cr -> detached
  detached -> pv: bind statically
  pv -> pvc: claim
  pvc -> pod: mount {style.bold: true}
}

# =============================================================================
# Flow 3 — Alert pipeline
# =============================================================================

alert_flow: "3 · Alert pipeline (Prometheus → phone)" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  targets: 32 scrape targets {
    shape: class
    label: |md
      node-exporter × 6
      kube-state-metrics
      Longhorn, Traefik
      Trivy, alertmanager...
    |
  }

  prom: Prometheus {
    shape: image
    icon: https://prometheus.io/assets/prometheus_logo_grey.svg
    style.fill: "#E6522C"
  }

  rules: PromQL alert rules\n(trivy, node, longhorn, etc.) {
    shape: document
    style.fill: "#FFCDD2"
  }

  am: Alertmanager {
    shape: image
    icon: https://prometheus.io/assets/alertmanager_logo_grey.svg
    style.fill: "#E6522C"
  }

  bridge: alertmanager-ntfy\nbridge {
    shape: hexagon
    style.fill: "#FFCA28"
    label: |md
      **alertmanager-ntfy**
      formats webhook →
      priority + tags +
      templated title/body
    |
  }

  ntfy_srv: self-hosted ntfy\n(athena · Docker) {
    shape: cylinder
    style.fill: "#FF7043"
  }

  cf_tunnel: Cloudflare Tunnel {
    shape: cloud
    style.fill: "#F48FB1"
  }

  ntfy_sh: ntfy.sh relay\n(iOS push) {
    shape: cloud
    style.fill: "#FFAB91"
  }

  phone: Phone (iOS) {
    shape: person
    style.fill: "#FFE0B2"
  }

  targets -> prom: scrape 30s
  prom -> rules: evaluate 30s
  rules -> am: fire (critical / warning)
  am -> bridge: webhook POST /hook
  bridge -> ntfy_srv: POST to localhost:8080/k8s-alerts
  ntfy_srv -> cf_tunnel: publish via tunnel
  cf_tunnel -> ntfy_sh: upstream-base-url
  ntfy_sh -> phone: push notification {style.bold: true}
}

# =============================================================================
# Flow 4 — Backup pipeline (PVC + etcd → R2)
# =============================================================================

backup_flow: "4 · Backup pipeline (PVC data + etcd state → R2)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  cronjob: Longhorn RecurringJob\ncritical-backup {
    shape: document
    style.fill: "#C8E6C9"
    label: |md
      **critical-backup**
      cron: 0 3 * * *
      groups: [critical]
      retain: 30
    |
  }

  critical_pvcs: 5 critical PVCs {
    shape: class
    label: |md
      gitea-shared-storage 10Gi
      monitoring/grafana 5Gi
      eve-tracker-data × 2
      open-webui-data 2Gi
    |
  }

  snapshot: Longhorn snapshot {
    shape: image
    icon: https://longhorn.io/img/logos/longhorn-icon-color.png
  }

  backup_engine: Longhorn backup engine {
    shape: image
    icon: https://longhorn.io/img/logos/longhorn-icon-color.png
  }

  etcd_cron: K3s embedded etcd\n(config.yaml) {
    shape: image
    icon: https://icons.terrastruct.com/dev%2Fetcd.svg
  }

  r2: Cloudflare R2 {
    shape: cloud
    style.fill: "#F48FB1"
    label: |md
      **k8sbkp bucket**
      - longhorn/ (PVC backups)
      - k3s-etcd-snapshots/
    |
  }

  cronjob -> critical_pvcs: select by group label
  critical_pvcs -> snapshot: crash-consistent
  snapshot -> backup_engine: incremental diff {style.bold: true}
  backup_engine -> r2: s3 PUT

  etcd_cron -> r2: etcd-s3 every 6h\nretain 12 {style.stroke: "#3F51B5"}
}

# =============================================================================
# Flow 5 — Version upgrade pipeline (Renovate → PR → manual review → apply)
# =============================================================================

upgrade_flow: "5 · Upgrade pipeline (Renovate → PR → apply)" {
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  renovate: Mend Renovate\n(GitHub App) {
    shape: cloud
    style.fill: "#FFE082"
    label: |md
      **Renovate (Mend)**
      weekly scan Mon < 9am CET
      free tier, hosted
    |
  }

  repo: GitHub repo {
    shape: image
    icon: https://github.githubassets.com/assets/GitHub-Mark-ea2971cee799.png
    style.fill: "#24292E"
  }

  managers: 4 custom regex managers {
    shape: class
    label: |md
      **renovate.json customManagers**
      - k3s_version (inventory)
      - kube_vip_version (role defaults)
      - alertmanager-ntfy image tag
      - wazuh_version (playbook)
    |
  }

  dashboard: Dependency Dashboard\n(GitHub issue) {
    shape: document
    style.fill: "#FFECB3"
  }

  pr: Renovate PR\n(per dependency / group) {
    shape: document
    style.fill: "#FFE082"
    label: |md
      **PR body**
      - checklist from packageRules
      - release notes link
      - K3s: manual-review label
    |
  }

  reviewer: Operator\n(manual review) {
    shape: person
    style.fill: "#FFE0B2"
  }

  checklist: K3s review checklist {
    shape: document
    style.fill: "#FFCC80"
    label: |md
      - [ ] Next-minor only (no skip)
      - [ ] Read release notes
      - [ ] Longhorn compat OK
      - [ ] etcd snapshot saved
      - [ ] Test on 1 node first
    |
  }

  merge: Merge PR {
    shape: step
    style.fill: "#FFB74D"
  }

  apply: ansible-playbook with\n--tags <stage> {
    shape: step
    style.fill: "#FFB74D"
    label: |md
      **Apply**
      - `make k3s` (K3s bump)
      - `--tags prometheus` (monitoring)
      - `make gitea` (Gitea)
      - etc.
    |
  }

  verify: Verify {
    shape: step
    style.fill: "#FFB74D"
    label: |md
      kubectl get nodes
      helm list -A
      /ready endpoints
    |
  }

  renovate -> repo: scan
  repo -> managers: parse customManagers
  managers -> dashboard: write summary
  managers -> pr: open PR per dep
  dashboard -> reviewer: notification
  pr -> reviewer: GitHub email
  reviewer -> checklist: K3s only
  checklist -> merge
  reviewer -> merge: approve
  merge -> apply: operator-driven\n(no auto-merge for K3s/Wazuh) {style.bold: true}
  apply -> verify
}

# =============================================================================
# Flow 6 — Nuke + full rebuild (make nuke && make all)
# =============================================================================

rebuild_flow: "6 · Full rebuild workflow (make nuke && make all)" {
  style: {
    fill: "#FCE4EC"
    stroke: "#AD1457"
    stroke-width: 2
    border-radius: 12
  }
  direction: right

  preflight: Pre-flight {
    shape: step
    style.fill: "#F8BBD9"
    label: |md
      **Pre-flight**
      - make backup
      - make restore-volumes-dry-run
      - verify R2 creds + 5 PVCs
      - approve Tailscale maint
      - note current helm versions
    |
  }

  nuke: make nuke {
    shape: step
    style.fill: "#F48FB1"
    label: |md
      **nuke-cluster.sh**
      - resolve hosts via tailnet IPs
      - detached nohup uninstall
      - poll until k3s binary gone
      - backup + remove kubeconfig
    |
  }

  prepare: make prepare {
    shape: step
    style.fill: "#CE93D8"
    label: |md
      01-prepare-nodes.yml
      apt, chrony, sysctl,
      /etc/hosts, registries.yaml
    |
  }

  k3s_install: make k3s {
    shape: step
    style.fill: "#CE93D8"
    label: |md
      02-install-k3s.yml
      serial:1 order:inventory:
      1. rpi-k3s-1 --cluster-init
      2. rpi-k3s-2 join (direct IP)
      3. rpi-k3s-3 join
      Then agents join via VIP
    |
  }

  post_install: make post-install + metallb + tailscale {
    shape: step
    style.fill: "#CE93D8"
    label: |md
      03-post-install.yml
      Helm repo bootstrap
      MetalLB IP pool
      Tailscale SSH + MagicDNS
      self-heal (-1 suffix)
    |
  }

  longhorn_backup: make longhorn + backup {
    shape: step
    style.fill: "#9FA8DA"
    label: |md
      Longhorn Helm install
      + BackupTarget CR
      + node storage tag
      + longhorn-storage class
      + RecurringJobs
    |
  }

  restore: make restore-volumes {
    shape: step
    style.fill: "#9FA8DA"
    label: |md
      12-restore-volumes.yml
      Wait for BV sync (≥ 5)
      Fail-fast on missing
      Volume CR + fromBackup
      PV/PVC + strip annotation
      (5-10 min per volume)
    |
  }

  apps: make monitoring + gitea + argocd {
    shape: step
    style.fill: "#90CAF9"
    label: |md
      04-deploy-monitoring.yml
      05-deploy-gitea.yml
      07-deploy-argocd.yml
      + Image Updater + eve-tracker apps
      Take-ownership of restored PVCs
    |
  }

  post_manual: Manual post-steps {
    shape: step
    style.fill: "#80CBC4"
    label: |md
      **Manual**
      - kubectl apply open-webui
      - 10-deploy-pihole-monitor.yml (Loki)
      - 09-deploy-ollama.yml (GPU)
      - Approve TS subnet routers
    |
  }

  validate: Post-rebuild validation {
    shape: step
    style.fill: "#80CBC4"
    label: |md
      kubectl get nodes (6)
      kubectl get pvc -A (7 bound)
      Smoke: gitea, grafana, argocd
      Test: k3s etcd-snapshot ls
      Kill test: stop 1 server
    |
  }

  operator: Operator {
    shape: person
    style.fill: "#FFE0B2"
  }

  operator -> preflight
  preflight -> nuke: **go** {style.bold: true; style.stroke: "#D32F2F"}
  nuke -> prepare: make all chain starts
  prepare -> k3s_install
  k3s_install -> post_install
  post_install -> longhorn_backup
  longhorn_backup -> restore: (critical — PVC data at stake)
  restore -> apps
  apps -> post_manual
  post_manual -> validate
}

# =============================================================================
# Flow 7 — etcd failover (single-node loss + double-node loss recovery)
# =============================================================================

failover_flow: "7 · etcd failover (HA quorum degradation + recovery)" {
  style: {
    fill: "#EFEBE9"
    stroke: "#4E342E"
    stroke-width: 2
    border-radius: 12
  }

  # Steady state
  steady: Steady state\n(3/3 members) {
    style.fill: "#C5E1A5"
    label: |md
      **Healthy**
      quorum = 2/3
      tolerates 1 loss
      kube-vip: 1 leader,
      2 standby
    |
  }

  # Single loss branch
  single_loss: Single-node loss\n(reboot / crash / drain) {
    shape: step
    style.fill: "#FFE082"
    label: |md
      e.g. rpi-k3s-2 reboots
    |
  }

  detect: Quorum recomputes\n(2/3 still ≥ majority) {
    shape: step
    style.fill: "#FFCC80"
  }

  vip_flip: kube-vip leader election\n(if leader was lost) {
    shape: step
    style.fill: "#FFCC80"
    label: |md
      Lease TTL 5s
      VIP fails over to
      surviving server
      (~3s gap)
    |
  }

  continue: Cluster continues {
    style.fill: "#C5E1A5"
    label: |md
      **Degraded but live**
      - API serving from 2 nodes
      - Deployments schedulable
      - Workloads untouched
      - etcd writes accepted
    |
  }

  recovery: Node recovers {
    shape: step
    style.fill: "#AED581"
    label: |md
      kubelet back
      etcd member rejoins
      catches up via raft log
      ~30s to healthy
    |
  }

  healed: Back to 3/3 {
    style.fill: "#C5E1A5"
  }

  # Double loss branch
  double_loss: Double-node loss\n(two servers gone) {
    shape: step
    style.fill: "#FFAB91"
  }

  quorum_lost: Quorum LOST\n(1 ≤ 2 majority) {
    shape: step
    style.fill: "#E57373"
    label: |md
      **Read-only cluster**
      - etcd stops accepting writes
      - API returns errors
      - kubelet keeps pods running
      - no new deploys
    |
  }

  triage: Triage {
    shape: step
    style.fill: "#FFAB91"
    label: |md
      Can both servers return?
      - YES → wait for rejoin
      - NO → restore flow
    |
  }

  restore_snap: etcd snapshot restore {
    shape: step
    style.fill: "#EF9A9A"
    label: |md
      **Last resort**
      1. Stop k3s on all servers
      2. k3s server --cluster-reset \\
         --cluster-reset-restore-path=<snap>
      3. Restart other servers
      4. Lost delta since snap
    |
  }

  r2_snaps: R2 etcd snapshots {
    shape: cloud
    style.fill: "#90CAF9"
    label: |md
      k8sbkp/k3s-etcd-snapshots/
      6h cadence · retain 12
    |
  }

  steady -> single_loss: happens
  single_loss -> detect
  detect -> vip_flip
  vip_flip -> continue
  continue -> recovery: when node\nreturns
  recovery -> healed

  steady -> double_loss: simultaneous\n(rare) {style.stroke: "#D32F2F"}
  double_loss -> quorum_lost
  quorum_lost -> triage
  triage -> restore_snap: NO rejoin path {style.bold: true}
  restore_snap -> r2_snaps: pulls latest
  restore_snap -> healed: ~10 min {style.stroke: "#4CAF50"}
}
