# Pi-hole DNS Monitor — Watch Patterns
# Format: wildcard_pattern = display label
# Lines starting with # are comments
# Reload: sudo systemctl reload pihole-dns-monitor
#
# Examples:
#   *.sme.sk = duck domain
#   *.facebook.com = social media
#   specific-site.org = specific site
#
{% for entry in monitor_watch_patterns %}
{{ entry.pattern }} = {{ entry.label }}
{% endfor %}
