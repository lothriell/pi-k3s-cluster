server:
  http_listen_port: {{ promtail_port }}
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ k3s_server_ip }}:31100/loki/api/v1/push

scrape_configs:
  - job_name: pihole
    static_configs:
      - targets:
          - localhost
        labels:
          job: pihole
          host: athena
          __path__: /var/log/pihole/pihole.log
    pipeline_stages:
      - regex:
          expression: '(?P<timestamp>\w+ \d+ [\d:]+) dnsmasq\[\d+\]: (?P<action>query|forwarded|reply|cached|blocked)\[?(?P<qtype>\w+)?\]?\s+(?P<domain>\S+)\s+(?:from|to|is)\s+(?P<target>\S+)'
      # Only LOW-cardinality fields become Loki labels (job, host, action,
      # qtype). `domain` and `target` are per-event and would explode Loki
      # stream cardinality — pi-hole sees thousands of unique domains in a
      # day, each becoming a new stream and tripping the default 10k
      # max_streams_per_user limit on Loki. They stay available in the raw
      # log line and can be filtered via LogQL line expressions:
      #   {job="pihole"} |= "redd.it"
      - labels:
          action:
          qtype:
