server:
  http_listen_port: {{ promtail_port }}
  grpc_listen_port: 0

positions:
  # NOT /tmp — /tmp is cleared on reboot AND on Docker container restart
  # (the promtail container uses a tmpfs on newer Docker). If the file
  # disappears, Promtail reads the pihole.log from offset 0 and re-ships
  # the entire retained log, which (a) blows past Loki stream limits and
  # (b) makes every old line land in Loki with a bogus "now" ingestion
  # timestamp. Persisted under /var/lib/promtail instead.
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://{{ k3s_server_ip }}:31100/loki/api/v1/push

scrape_configs:
  - job_name: pihole
    static_configs:
      - targets:
          - localhost
        labels:
          job: pihole
          host: athena
          # Glob picks up today's pihole.log + yesterday's rotated pihole.log.1
          # so a Promtail restart after midnight doesn't lose the previous day's
          # tail (rotation runs at 22:00 UTC nightly).
          __path__: /var/log/pihole/pihole.log{,.1}
    pipeline_stages:
      # `\w+\s+\d+\s+[\d:]+` (NOT `\w+ \d+ [\d:]+`): dnsmasq space-pads
      # single-digit days ("May  6" — TWO spaces between month and day).
      # The single-space regex silently fails for days 1-9 of any month,
      # which falls back to `action_on_failure: fudge` → all entries get
      # the last-good timestamp + 1ns each. Caught 2026-05-06 after 6
      # days of "May 1-6" entries arriving in Loki stamped April 30.
      - regex:
          expression: '(?P<timestamp>\w+\s+\d+\s+[\d:]+) dnsmasq\[\d+\]: (?P<action>query|forwarded|reply|cached|blocked)\[?(?P<qtype>\w+)?\]?\s+(?P<domain>\S+)\s+(?:from|to|is)\s+(?P<target>\S+)'

      # CRITICAL: feed the parsed timestamp back into Loki's entry time.
      # Without this stage, Loki timestamps every line with ingestion
      # wall-clock ("now()"), causing two visible problems in Grafana:
      #   1. All lines in a batch share the same Loki timestamp
      #      (looks like `2026-04-15 20:14:36` on 5 different events)
      #   2. Replayed logs (after Promtail restart or position file
      #      loss) are off by hours — line content says 17:22 CET but
      #      Loki plots them at 20:14 CET.
      # Go reference time: `_2` handles both `Apr 5` (space-padded) and
      # `Apr 15` (no pad) — dnsmasq uses space-padding for single-digit
      # days. `Local` interprets in athena's TZ (CET) since dnsmasq
      # writes local time, not UTC.
      - timestamp:
          source: timestamp
          format: "Jan _2 15:04:05"
          location: Local

      # Only LOW-cardinality fields become Loki labels (job, host, action,
      # qtype). `domain` and `target` are per-event and would explode Loki
      # stream cardinality — pi-hole sees thousands of unique domains in a
      # day, each becoming a new stream and tripping the default 10k
      # max_streams_per_user limit on Loki. They stay available in the raw
      # log line and can be filtered via LogQL line expressions:
      #   {job="pihole"} |= "redd.it"
      #   {job="pihole"} |= "from <client-ip>"
      # 2026-05-06: `target` was leaking into labels here despite the warning
      # above. Once the regex started matching properly, every reply IP
      # became a Loki stream → query 400 "max series (500) reached" → Loki
      # OOMKilled at 512Mi. Don't add it back. If you really need IP-based
      # filtering, use a line filter (above) — slower per-query, but no
      # cardinality risk.
      - labels:
          action:
          qtype:
