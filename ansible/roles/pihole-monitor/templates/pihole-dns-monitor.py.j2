#!/usr/bin/env python3
"""Monitor Pi-hole DNS logs and alert on matching queries via ntfy.

Reads alert rules from a single config file. Each rule can specify:
  - domain pattern + specific IP  → alert only for that IP
  - domain pattern + *            → alert for ANY IP querying that domain

Config reload: send SIGHUP to re-read rules without restart.
"""

import subprocess
import re
import signal
import fnmatch
import urllib.request


RULES_FILE = "{{ monitor_config_dir }}/alert-rules.conf"
NTFY_URL = "http://localhost:{{ ntfy_port }}/{{ ntfy_topic }}"
LOG_FILE = "{{ pihole_log_file }}"


def log(msg):
    print(msg, flush=True)


def load_rules(path):
    """Load alert rules from config file.

    Format per line:
        domain_pattern | ip_or_* | label
    Examples:
        *.sme.sk | 10.69.0.42 | duck domain
        *.facebook.com | * | social media
        bad-site.org | 10.69.0.42 | phishing
    """
    rules = []
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = [p.strip() for p in line.split("|")]
                if len(parts) == 3:
                    domain_pat, ip_pat, label = parts
                    rules.append((domain_pat, ip_pat, label))
                elif len(parts) == 2:
                    domain_pat, label = parts
                    rules.append((domain_pat, "*", label))
                else:
                    log(f"WARNING: invalid rule: {line}")
    except FileNotFoundError:
        log(f"WARNING: {path} not found")
    return rules


def reload_config(signum=None, frame=None):
    global rules
    rules = load_rules(RULES_FILE)
    log(f"Config loaded: {len(rules)} alert rules")
    for domain_pat, ip_pat, label in rules:
        log(f"  {domain_pat} | {ip_pat} | {label}")


def send_alert(domain, client_ip, label):
    """Send notification via ntfy."""
    msg = f"User {client_ip} accessed {label}"
    body = f"Domain: {domain}\nClient: {client_ip}\nLabel: {label}"
    try:
        req = urllib.request.Request(
            NTFY_URL,
            data=body.encode(),
            headers={
                "Title": msg,
                "Priority": "high",
                "Tags": "warning",
            },
        )
        urllib.request.urlopen(req, timeout=5)
        log(f"ALERT: {msg} ({domain})")
    except Exception as e:
        log(f"ERROR sending alert: {e}")


def matches_ip(client_ip, ip_pattern):
    """Check if client IP matches the rule's IP pattern."""
    if ip_pattern == "*":
        return True
    return client_ip == ip_pattern


# Regex: "query[A] domain.name from 10.x.x.x"
QUERY_RE = re.compile(r"query\[\w+\]\s+(\S+)\s+from\s+(\S+)")

# Load initial config
rules = []
reload_config()

# Reload config on SIGHUP
signal.signal(signal.SIGHUP, reload_config)

log(f"Starting Pi-hole DNS monitor, tailing {LOG_FILE}")

# Tail the log file
proc = subprocess.Popen(
    ["tail", "-n", "0", "-F", LOG_FILE],
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
    text=True,
)

try:
    for line in proc.stdout:
        m = QUERY_RE.search(line)
        if not m:
            continue
        domain, client_ip = m.group(1), m.group(2)
        for domain_pat, ip_pat, label in rules:
            if fnmatch.fnmatch(domain, domain_pat) and matches_ip(client_ip, ip_pat):
                send_alert(domain, client_ip, label)
                break
except KeyboardInterrupt:
    log("Shutting down")
finally:
    proc.terminate()
