# Pi-hole DNS Monitor — Alert Rules
# Format: domain_pattern | ip_or_* | display_label
#
# Use * for IP to match ALL clients.
# Lines starting with # are comments.
# Reload: sudo systemctl reload pihole-dns-monitor
#
# Examples:
#   *.sme.sk | 10.69.0.42 | duck domain          ← only this IP
#   *.facebook.com | * | social media             ← any IP
#   bad-site.org | 10.69.0.42 | phishing          ← exact domain + IP
#
{% for rule in monitor_alert_rules %}
{{ rule.pattern }} | {{ rule.ip | default('*') }} | {{ rule.label }}
{% endfor %}
