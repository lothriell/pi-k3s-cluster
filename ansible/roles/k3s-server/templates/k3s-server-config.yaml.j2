# K3s server configuration
# This file is managed by Ansible - do not edit manually.
# Place at /etc/rancher/k3s/config.yaml if you prefer file-based config.

# Disable the built-in ServiceLB (Klipper) in favour of MetalLB
disable:
  - servicelb

# Allow non-root users to read the kubeconfig
write-kubeconfig-mode: "0644"

# Additional SANs for the API server TLS certificate
tls-san:
  - "{{ k3s_server_ip }}"
  - "{{ inventory_hostname }}"

# Flannel backend (default is vxlan, which works well on ARM64)
# flannel-backend: vxlan
