---
# /etc/rancher/k3s/config.yaml — persistent K3s server config.
#
# CLI flags in the install command handle one-time bootstrap options
# (`--cluster-init`, `--server`, token). This file holds ongoing runtime
# config that must survive reinstalls; K3s's install script does NOT
# overwrite this file (unlike /etc/systemd/system/k3s.service.env).
#
# Mode 0600, owned by root — do not put secrets in the systemd unit file.

# --- etcd tuning ---
# Default 1.5 MB is too small for large Trivy VulnerabilityReports
# (e.g. Open WebUI image produces reports >1.5 MB). 8 MB is the
# etcd hard maximum; 4 MB gives plenty of headroom without risk.
etcd-arg:
  - "max-request-bytes=4194304"

# --- kubelet tuning ---
# Pi nodes have 32 GB eMMC. Default image-gc thresholds (85%/80%) trigger
# too late; ArgoCD Image Updater churn fills /var/lib/rancher/k3s/agent/
# containerd well before that. Prune aggressively at 75%, down to 60%.
kubelet-arg:
  - "image-gc-high-threshold=75"
  - "image-gc-low-threshold=60"

{% if r2_access_key_id is defined %}
# --- Embedded etcd offsite snapshots (Cloudflare R2 via S3 API) ---
# K3s's built-in snapshot loop handles scheduling, retention, and upload.
# Replaces the SQLite-era /usr/local/bin/k3s-sqlite-backup.sh timer.
etcd-s3: true
etcd-s3-access-key: "{{ r2_access_key_id }}"
etcd-s3-secret-key: "{{ r2_secret_access_key }}"
etcd-s3-endpoint: "{{ r2_endpoint_host }}"
etcd-s3-bucket: "{{ r2_backup_bucket }}"
etcd-s3-folder: "k3s-etcd-snapshots"
etcd-snapshot-schedule-cron: "0 */6 * * *"
etcd-snapshot-retention: 12
{% endif %}
