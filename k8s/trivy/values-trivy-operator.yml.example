# =============================================================================
# Trivy Operator — Helm values
# =============================================================================
# Installed via `make trivy-operator` into the trivy-system namespace.
# Chart defaults already expose Prometheus metrics on pod port 8080 via a
# Service named `trivy-operator` with a named port `metrics`. Prometheus
# picks this up through extraScrapeConfigs (see
# k8s/monitoring/values-prometheus.yml.j2, job_name=trivy-operator).
# =============================================================================

# Keep scan pressure light on a 6-node mixed-arch cluster (4 Pi + 2 x86)
operator:
  scanJobsConcurrentLimit: 3
  scanJobsRetryDelay: 30s
  # Use the built-in Trivy server so scan jobs query it over HTTP instead of
  # each downloading their own DB copy. Eliminates "cache may be in use by
  # another process: timeout" errors from concurrent scan jobs.
  builtInTrivyServer: true
  vulnerabilityScannerEnabled: true
  configAuditScannerEnabled: true
  rbacAssessmentScannerEnabled: true
  infraAssessmentScannerEnabled: true
  clusterComplianceEnabled: true
  exposedSecretScannerEnabled: true
  metricsVulnIdEnabled: false

# Pin operator + scan jobs to the x86 agents so ARM64 Pis stay responsive.
nodeSelector:
  kubernetes.io/arch: amd64

trivy:
  # ClientServer mode: scan jobs send image refs to the built-in Trivy server
  # which holds the vulnerability DB persistently. No per-job DB download,
  # no cache lock contention.
  mode: ClientServer
  serverURL: "http://trivy-service.trivy-system.svc.cluster.local:4954"

  # Same arch constraint for the scanner sidecars spawned by scan jobs
  nodeSelector:
    kubernetes.io/arch: amd64
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi
  ignoreUnfixed: true
  severity: "CRITICAL,HIGH,MEDIUM"

  # Gitea container registry is HTTP-only. Without this, Trivy tries HTTPS
  # and fails with TLS handshake errors.
  insecureRegistries:
    gitea: "gitea-http.gitea.svc.cluster.local:3000"

  # Map the external hostname used in image refs to the in-cluster service
  # so the Trivy server can pull images without depending on CoreDNS NodeHosts
  # or MetalLB VIP routing.
  registry:
    mirror:
      "gitea.<local_domain>": "gitea-http.gitea.svc.cluster.local:3000"

  # Trivy server resources and storage
  server:
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi

  # 5Gi PVC for the vulnerability DB
  # longhorn-storage class pins replicas to x86 nodes (Pi eMMC is small;
  # the trivy DB is rebuilt frequently, no Pi-local advantage).
  storageClassEnabled: true
  storageClassName: "longhorn-storage"
  storageSize: "5Gi"

# ServiceMonitor is off — monitoring scrapes via extraScrapeConfigs with
# kubernetes_sd_configs (works before/without kube-prometheus-stack CRDs).
serviceMonitor:
  enabled: false

# Minimal resources for the operator pod itself
resources:
  requests:
    cpu: 50m
    memory: 128Mi
  limits:
    cpu: 500m
    memory: 1Gi
