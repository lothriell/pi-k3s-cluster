# =============================================================================
# Local domain ingress rules for *.{{ local_domain }}
# =============================================================================
# Rendered by 03-post-install.yml from Jinja2 template using vars in
# ansible/inventory/group_vars/all/main.yml (gitignored).
#
# Routes local domain names to cluster services via Traefik.
# Requires DNS resolution of *.{{ local_domain }} -> Traefik LB IP (MetalLB).
# =============================================================================

---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana-local
  namespace: monitoring
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  rules:
    - host: grafana.{{ local_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: grafana
                port:
                  number: 80

