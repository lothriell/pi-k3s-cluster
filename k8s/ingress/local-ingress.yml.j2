# =============================================================================
# Ollama -- external GPU server proxied through Traefik
# =============================================================================
# Ollama runs on a GPU server outside K8s. We create a headless Service +
# Endpoints pointing to its LAN IP, then an Ingress to route traffic.
# =============================================================================

---
apiVersion: v1
kind: Endpoints
metadata:
  name: ollama-external
  namespace: default
subsets:
  - addresses:
      - ip: {{ gpu_node_ip_1 }}
    ports:
      - port: 11434

---
apiVersion: v1
kind: Service
metadata:
  name: ollama-external
  namespace: default
spec:
  ports:
    - port: 11434
      targetPort: 11434

---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ollama-local
  namespace: default
  annotations:
    cert-manager.io/cluster-issuer: homielab-internal
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - ollama.{{ local_domain }}
      secretName: ollama-local-tls
  rules:
    - host: ollama.{{ local_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ollama-external
                port:
                  number: 11434

---
# Vaultwarden — TLS via internal CA. Replaces the previously hand-rolled
# self-signed cert (memory project_vaultwarden) once cert-manager mints
# vaultwarden-tls into the vaultwarden namespace.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vaultwarden-local
  namespace: vaultwarden
  annotations:
    cert-manager.io/cluster-issuer: homielab-internal
