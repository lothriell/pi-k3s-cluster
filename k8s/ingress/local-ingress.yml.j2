# =============================================================================
# Local domain ingress rules for *.{{ local_domain }}
# =============================================================================
# Rendered by 03-post-install.yml from Jinja2 template using vars in
# ansible/inventory/group_vars/all/main.yml (gitignored).
#
# Routes local domain names to cluster services via Traefik on the
# `websecure` (HTTPS) entrypoint. TLS certs are minted automatically by
# cert-manager from the in-cluster `homielab-internal` CA — see
# k8s/cert-manager/cluster-issuer.yml for the chain. Each Ingress carries:
#   annotations:
#     cert-manager.io/cluster-issuer: homielab-internal
#     traefik.ingress.kubernetes.io/router.entrypoints: websecure
#     traefik.ingress.kubernetes.io/router.tls: "true"
#   spec.tls:
#     - hosts: [<host>]
#       secretName: <host-slug>-tls
#
# HTTP→HTTPS redirect is cluster-wide via k8s/traefik/helm-chart-config.yml,
# so no per-Ingress redirect middleware is required.
#
# Trust the homielab CA on each client once. See docs/internal-ca-trust.md.
#
# Requires DNS resolution of *.{{ local_domain }} -> Traefik LB IP (MetalLB).
# =============================================================================

---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana-local
  namespace: monitoring
  annotations:
    cert-manager.io/cluster-issuer: homielab-internal
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - grafana.{{ local_domain }}
      secretName: grafana-local-tls
  rules:
    - host: grafana.{{ local_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: grafana
                port:
                  number: 80

