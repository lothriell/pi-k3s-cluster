# =============================================================================
# Ollama -- external GPU server proxied through Traefik
# =============================================================================
# Ollama runs on a GPU server outside K8s. We create a headless Service +
# Endpoints pointing to its LAN IP, then an Ingress to route traffic.
# =============================================================================

---
apiVersion: v1
kind: Endpoints
metadata:
  name: ollama-external
  namespace: default
subsets:
  - addresses:
      - ip: {{ gpu_node_ip_1 }}
    ports:
      - port: 11434

---
apiVersion: v1
kind: Service
metadata:
  name: ollama-external
  namespace: default
spec:
  ports:
    - port: 11434
      targetPort: 11434

---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ollama-local
  namespace: default
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  rules:
    - host: ollama.{{ local_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ollama-external
                port:
                  number: 11434

---
# Vaultwarden requires HTTPS (browser SubtleCrypto API unavailable otherwise).
# TLS secret is a self-signed cert for vault.<local_domain> — first visit will
# prompt the user to accept the cert; subsequent visits are cached.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vaultwarden-local
  namespace: vaultwarden
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  tls:
    - hosts:
        - vault.{{ local_domain }}
      secretName: vaultwarden-tls
  rules:
    - host: vault.{{ local_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: vaultwarden
                port:
                  number: 80
