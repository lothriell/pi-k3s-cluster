---
# Gitignored LAN Ingress for Longhorn UI.
# Copy this file to ingress.local.yml, replace the host with your actual
# local domain, then apply:
#
#     cp k8s/longhorn/ingress.local.yml.example k8s/longhorn/ingress.local.yml
#     # edit the host in the new file
#     kubectl apply -f k8s/longhorn/ingress.local.yml
#
# Longhorn UI does not have built-in authentication — keep it LAN-only
# (do NOT expose via Cloudflare Tunnel or public DNS).
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: longhorn-local
  namespace: longhorn-system
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  ingressClassName: traefik
  rules:
    # TODO CHANGEME
    - host: longhorn.example.local
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: longhorn-frontend
                port:
                  number: 80
