# Forgejo admin credentials -- DO NOT commit real values.
# The deploy playbook (06-deploy-forgejo.yml) creates this secret from
# ansible-vault variables: forgejo_admin_user, forgejo_admin_password,
# forgejo_admin_email.
#
# Manual alternative:
#   kubectl -n forgejo create secret generic forgejo-admin-secret \
#     --from-literal=username=forgejo_admin \
#     --from-literal=password=CHANGEME \
#     --from-literal=email=admin@example.com
---
apiVersion: v1
kind: Secret
metadata:
  name: forgejo-admin-secret
  namespace: forgejo
type: Opaque
stringData:
  username: forgejo_admin
  email: "CHANGEME@example.com"
  password: "CHANGEME_STRONG_PASSWORD"
