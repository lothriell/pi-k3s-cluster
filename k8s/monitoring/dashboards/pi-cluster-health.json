          },
          "unit": "iops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(longhorn_volume_read_iops[5m])",
          "legendFormat": "{{volume}} read",
          "refId": "A"
        },
        {
          "expr": "rate(longhorn_volume_write_iops[5m])",
          "legendFormat": "{{volume}} write",
          "refId": "B"
