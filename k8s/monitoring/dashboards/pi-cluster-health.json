        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "longhorn_volume_actual_size_bytes",
          "legendFormat": "{{volume}}",
          "refId": "A"
        }
      ]
