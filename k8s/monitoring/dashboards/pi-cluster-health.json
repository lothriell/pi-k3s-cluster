              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "node_thermal_zone_temp{type=\"cpu-thermal\"}",
          "legendFormat": "{{instance}}"
