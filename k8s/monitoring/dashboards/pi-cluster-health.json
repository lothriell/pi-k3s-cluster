    {
      "title": "Node Uptime",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3600
              },
              {
                "color": "green",
                "value": 86400
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Longhorn Storage Capacity vs Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "longhorn_disk_capacity_bytes",
          "legendFormat": "{{node}} capacity",
          "refId": "A"
        },
        {
          "expr": "longhorn_disk_usage_bytes",
          "legendFormat": "{{node}} used",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Longhorn Storage Usage %",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(longhorn_disk_usage_bytes / longhorn_disk_capacity_bytes) * 100",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Longhorn Volume Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "options": {
                "1": {
                  "text": "Attached"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "0": {
                  "text": "Detached"
                }
              },
              "type": "value"
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "longhorn_volume_robustness == 1",
          "legendFormat": "{{volume}} ({{node}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Longhorn Volume Actual Size",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "bytes"
